<%- include('partials/header') %>

<div class="page page-secret">
  <div class="container">
    <h1 class="secret-title">You've Discovered My Secret!</h1>

    <div class="secret-banner" role="note">
      Jack Bauer is my hero.
    </div>

    <div class="secret-text" aria-live="polite">
      <%= secret %>
    </div>

    <div class="hero-actions secret-actions">
      <a class="btn btn-bank" href="/logout" role="button">Log Out</a>
      <a class="btn btn-bank" href="/submit" role="button">Submit a Secret</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
